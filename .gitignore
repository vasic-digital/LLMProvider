# LLMProvider .gitignore — CONST-053 compliant
# (cascaded from constitution submodule §11.4.30)

# Build artefacts (CONST-053 class 1)
/bin/
/build/
/dist/
/out/
target/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.a
*.o
*.test
vendor/

# Cache files (CONST-053 class 2)
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
.cache/
.gradle/
.terraform/

# Temp files (CONST-053 class 3)
*.tmp
*.swp
*.swo
*~
*.orig
*.rej

# Sensitive-data files (CONST-053 class 4 + CONST-042 §12.1)
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# Generated reports / logs (CONST-053 class 5)
*.log
*.out
coverage.out
htmlcov/
reports/
reports/demos/

# OS / IDE personal state (CONST-053 class 6)
.DS_Store
Thumbs.db
.idea/
.history/
.vscode/
