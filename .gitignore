# LLMProvider .gitignore — CONST-053 compliant
# (cascaded from constitution submodule §11.4.30)
# Round-341 merge-first reconciliation (CONST-061): union of the
# round-292 vasic-digital twin and the HelixDevelopment lineage
# .gitignore — every pattern from both kept.

# Environment / secrets (CONST-042 §12.1 + CONST-053 class 4)
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# Build artefacts (CONST-053 class 1)
/bin/
/build/
/dist/
/out/
target/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.a
*.o
*.class
*.pyc
vendor/

# Cache files (CONST-053 class 2)
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
.cache/
.gradle/
.terraform/

# Temp files (CONST-053 class 3)
*.tmp
*.swp
*.swo
*~
*.orig
*.rej

# OS / IDE personal state (CONST-053 class 6)
.idea/
.history/
.vscode/
.DS_Store
Thumbs.db

# Generated reports / logs (CONST-053 class 5)
*.log
coverage.out
htmlcov/
reports/
reports/demos/

# Stray go-build artefacts at repo root
/runner
